    {
      "id": "keep_exposure_after_close",
      "type": "value_forcing",
      "target": "close_position",
      "field": "exposure",
      "forced_value": 1,
      "expected_failure": "state_model"
    },
    {
      "id": "force_zero_pnl",
      "type": "value_forcing",
      "target": "calculate_pnl",
      "field": "pnl",
      "forced_value": 0,
      "expected_failure": "tests"
    }
  ]
