{
  "module": "pnl_engine",
  "description": "Hardcore mutations for PnL integrity, exposure closeout, and sign correctness.",
  "mutations": [
    {
      "id": "ignore_loss",
      "type": "logic_replace",
      "target": "calculate_pnl",
      "mode": "clamp_loss_to_zero",
      "expected_failure": "tests"
    },
    {
      "id": "invert_profit_sign",
      "type": "math_corruption",
      "target": "calculate_pnl",
      "mode": "invert_sign",
      "expected_failure": "tests"
    },
    {
      "id": "skip_close_update",
      "type": "call_remove",
      "target": "close_position",
