{
  "module": "core.execution_guard",
  "description": "Hardcore mutations for exactly-once and dedup enforcement.",
  "mutations": [
    {
      "id": "skip_dedup_check",
      "type": "call_remove",
      "target": "check_duplicate",
      "call_name": "lookup_existing_key",
      "expected_failure": "tests"
    },
    {
      "id": "always_allow_execution",
      "type": "branch_forcing",
      "target": "enforce_exactly_once",
      "forced_outcome": "allow",
      "expected_failure": "tests"
    },
    {
      "id": "drop_action_id_from_key",
      "type": "key_corruption",
      "target": "build_dedup_key",
      "field": "action_id",
      "expected_failure": "tests"
    },
    {
      "id": "drop_customer_ref_from_key",
      "type": "key_corruption",
      "target": "build_dedup_key",
      "field": "customer_ref",
      "expected_failure": "tests"
    },
    {
      "id": "use_ram_only_no_db",
      "type": "storage_bypass",
      "target": "register_execution",
      "mode": "ram_only",
      "expected_failure": "spec"
    },
    {
      "id": "allow_missing_key",
      "type": "branch_forcing",
      "target": "check_duplicate",
      "branch": "missing_key_deny",
      "forced_outcome": "allow",
      "expected_failure": "contract"
    }
  ]
}